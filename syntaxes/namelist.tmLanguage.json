{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PawnPro Name List",
  "scopeName": "source.pawnpro-namelist",
  "patterns": [
    { "include": "#comment" },
    { "include": "#term" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.pawnpro-namelist"
    },
    "term": {
      "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "captures": {
        "1": { "name": "entity.name.tag.pawnpro-namelist" }
      }
    }
  }
}
