{
  "name": "PAWN",
  "scopeName": "source.pawn",
  "fileTypes": ["pwn", "inc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#storage" },
    { "include": "#labels" },
    { "include": "#namespace_call" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.pawn", "match": "//.*$" },
        {
          "name": "comment.block.pawn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.pawn",
          "begin": "^[\\t ]*#\\s*(?:(include|tryinclude|define|undef|if|ifdef|ifndef|else|elseif|endif|emit|pragma|endinput|error|warning|assert|file|line))\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.pawn" }
          },
          "end": "$",
          "patterns": [
            { "name": "support.other.include.path.pawn", "match": "<[^>]+>" },
            {
              "name": "support.other.include.path.pawn",
              "match": "\"([^\"\\\\]|\\\\.)*\""
            },
            { "include": "#comments" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pawn",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.pawn", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.pawn",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.pawn", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.pawn",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.decimal.pawn",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pawn",
          "match": "\\b(if|else|do|while|for|break|continue|switch|case|default|return|goto|assert|exit|sleep|state)\\b"
        },
        {
          "name": "keyword.operator.pawn",
          "match": "\\b(sizeof|tagof|defined)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pawn",
          "match": "\\b(bool|Float|float|char|String|enum|struct)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.modifier.pawn",
          "match": "\\b(const|static|stock|public|native|forward|new)\\b"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "comment": "goto labels only: must be at start of line, followed by : but NOT preceded by an identifier on the same token (avoids matching tag:var). Negative lookahead avoids tag:ident patterns.",
          "name": "entity.name.label.pawn",
          "match": "^[\\t ]*([A-Za-z_][\\w]*)\\s*:(?![:\\s]*[A-Za-z_\\(])",
          "captures": { "1": { "name": "entity.name.label.pawn" } }
        }
      ]
    },
    "namespace_call": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][\\w]*)(::)([A-Za-z_][\\w]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.namespace.pawn" },
            "2": { "name": "punctuation.accessor.double-colon.pawn" },
            "3": { "name": "entity.name.function.pawn" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function calls — excludes control flow keywords handled by #keywords",
          "name": "entity.name.function.pawn",
          "match": "\\b(?!if|else|do|while|for|switch|return|goto|assert|exit|sleep|state|sizeof|tagof|defined\\b)([A-Za-z_][\\w]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.pawn", "match": "\\b(true|false)\\b" },
        {
          "name": "constant.other.define.pawn",
          "match": "\\b[A-Z_][A-Z0-9_]{2,}\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.paren.open.pawn", "match": "\\(" },
        { "name": "punctuation.paren.close.pawn", "match": "\\)" },
        { "name": "punctuation.bracket.open.pawn", "match": "\\[" },
        { "name": "punctuation.bracket.close.pawn", "match": "\\]" },
        { "name": "punctuation.brace.open.pawn", "match": "\\{" },
        { "name": "punctuation.brace.close.pawn", "match": "\\}" }
      ]
    }
  },
  "uuid": "e3a3a0e6-7f6d-4c8d-9c91-9f1f3a2a8e10"
}
