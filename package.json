{
  "name": "pawnpro",
  "displayName": "PawnPro",
  "description": "%text.description%",
  "version": "3.1.0",
  "publisher": "NullSablex",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "vscode": "^1.106.0"
  },
  "platforms": [
    "linux-x64",
    "linux-arm64",
    "win32-x64",
    "darwin-x64",
    "darwin-arm64"
  ],
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "pawn",
    "sa-mp",
    "samp",
    "gta",
    "pwn",
    "server",
    "rcon"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "bugs": {
    "url": "https://github.com/NullSablex/PawnPro/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NullSablex/PawnPro"
  },
  "icon": "images/logo.png",
  "engineVersion": "1.0.0",
  "engineRepository": "https://github.com/NullSablex/PawnPro-Engine",
  "author": {
    "name": "NullSablex",
    "url": "https://github.com/NullSablex"
  },
  "main": "./out/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pawnpro",
          "title": "PawnPro",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "pawnpro": [
        {
          "id": "pawnpro.includesView",
          "name": "Includes",
          "icon": "symbol-method"
        },
        {
          "id": "pawnpro.serverView",
          "name": "Servidor",
          "icon": "symbol-method",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pawnpro.compileCurrent",
        "key": "ctrl+alt+b",
        "when": "editorLangId == pawn && editorTextFocus"
      }
    ],
    "snippets": [
      {
        "language": "pawn",
        "path": "./snippets/pawn.json"
      }
    ],
    "grammars": [
      {
        "language": "pawn",
        "scopeName": "source.pawn",
        "path": "./syntaxes/pawn.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "pawn",
        "scopes": {
          "function": ["support.function.pawn"]
        }
      }
    ],
    "languages": [
      {
        "id": "pawn",
        "aliases": [
          "PAWN",
          "pawn"
        ],
        "extensions": [
          ".pwn",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "pawnpro.compileCurrent",
        "title": "%command.compile%"
      },
      {
        "command": "pawnpro.detectCompiler",
        "title": "%command.detect%"
      },
      {
        "command": "pawnpro.applySyntaxScheme",
        "title": "%command.applySyntaxScheme%"
      },
      {
        "command": "pawnpro.resetSyntaxScheme",
        "title": "%command.resetSyntaxScheme%"
      },
      {
        "command": "pawnpro.server.start",
        "title": "%command.server.start%",
        "icon": "$(debug-start)"
      },
      {
        "command": "pawnpro.server.stop",
        "title": "%command.server.stop%",
        "icon": "$(debug-stop)"
      },
      {
        "command": "pawnpro.server.restart",
        "title": "%command.server.restart%",
        "icon": "$(debug-restart)"
      },
      {
        "command": "pawnpro.server.show",
        "title": "%command.server.show%",
        "icon": "$(terminal)"
      },
      {
        "command": "pawnpro.server.showLog",
        "title": "%command.server.showLog%",
        "icon": "$(output)"
      },
      {
        "command": "pawnpro.clearEngineCache",
        "title": "%command.clearEngineCache%"
      },
      {
        "command": "pawnpro.whatsNew",
        "title": "%command.whatsNew%"
      },
      {
        "command": "pawnpro.newScript",
        "title": "%command.newScript%"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "PawnPro",
      "properties": {
        "pawnpro.includePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%config.includePaths%"
        },
        "pawnpro.compiler.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.compiler.path%"
        },
        "pawnpro.compiler.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%config.compiler.args%"
        },
        "pawnpro.compiler.autoDetect": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.compiler.autoDetect%"
        },
        "pawnpro.output.encoding": {
          "type": "string",
          "default": "windows1252",
          "markdownDescription": "%config.output.encoding%"
        },
        "pawnpro.build.showCommand": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.build.showCommand%"
        },
        "pawnpro.syntax.scheme": {
          "type": "string",
          "enum": ["auto", "classic_white", "modern_white", "classic_dark", "modern_dark", "none"],
          "enumDescriptions": [
            "%config.syntax.scheme.auto%",
            "%config.syntax.scheme.classic_white%",
            "%config.syntax.scheme.modern_white%",
            "%config.syntax.scheme.classic_dark%",
            "%config.syntax.scheme.modern_dark%",
            "%config.syntax.scheme.none%"
          ],
          "default": "none",
          "markdownDescription": "%config.syntax.scheme%"
        },
        "pawnpro.syntax.applyOnStartup": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.syntax.applyOnStartup%"
        },
        "pawnpro.ui.showIncludePaths": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.ui.showIncludePaths%"
        },
        "pawnpro.analysis.warnUnusedInInc": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.analysis.warnUnusedInInc%"
        },
        "pawnpro.analysis.sdk.platform": {
          "type": "string",
          "enum": ["omp", "samp", "none"],
          "enumDescriptions": [
            "%config.analysis.sdk.platform.omp%",
            "%config.analysis.sdk.platform.samp%",
            "%config.analysis.sdk.platform.none%"
          ],
          "default": "omp",
          "markdownDescription": "%config.analysis.sdk.platform%"
        },
        "pawnpro.analysis.sdk.filePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.analysis.sdk.filePath%"
        },
        "pawnpro.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.server.path%"
        },
        "pawnpro.server.cwd": {
          "type": "string",
          "default": "${workspaceFolder}",
          "markdownDescription": "%config.server.cwd%"
        },
        "pawnpro.server.args": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "%config.server.args%"
        },
        "pawnpro.server.clearOnStart": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.server.clearOnStart%"
        },
        "pawnpro.server.logPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.server.logPath%"
        },
        "pawnpro.server.logEncoding": {
          "type": "string",
          "default": "windows1252",
          "markdownDescription": "%config.server.logEncoding%"
        },
        "pawnpro.server.output.follow": {
          "type": "string",
          "enum": ["visible", "always", "off"],
          "enumDescriptions": [
            "%config.server.output.follow.visible%",
            "%config.server.output.follow.always%",
            "%config.server.output.follow.off%"
          ],
          "default": "visible",
          "markdownDescription": "%config.server.output.follow%"
        },
        "pawnpro.server.type": {
          "type": "string",
          "enum": [
            "auto",
            "samp",
            "omp"
          ],
          "enumDescriptions": [
            "%config.server.type.auto%",
            "%config.server.type.samp%",
            "%config.server.type.omp%"
          ],
          "default": "auto",
          "markdownDescription": "%config.server.type%"
        }
      }
    },
    "configurationDefaults": {
      "[pawn]": {
        "files.encoding": "windows1252"
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "pawnpro.server.start",
          "when": "view == pawnpro.serverView && !pawnpro.server.running",
          "group": "navigation"
        },
        {
          "command": "pawnpro.server.stop",
          "when": "view == pawnpro.serverView && pawnpro.server.running",
          "group": "navigation"
        },
        {
          "command": "pawnpro.server.restart",
          "when": "view == pawnpro.serverView && pawnpro.server.running",
          "group": "navigation@1"
        },
        {
          "command": "pawnpro.server.show",
          "when": "view == pawnpro.serverView",
          "group": "navigation@2"
        },
        {
          "command": "pawnpro.server.showLog",
          "when": "view == pawnpro.serverView && pawnpro.server.running",
          "group": "navigation@3"
        },
        {
          "command": "pawnpro.server.start",
          "when": "view == pawnpro.serverView.explorer && !pawnpro.server.running",
          "group": "navigation"
        },
        {
          "command": "pawnpro.server.stop",
          "when": "view == pawnpro.serverView.explorer && pawnpro.server.running",
          "group": "navigation"
        },
        {
          "command": "pawnpro.server.restart",
          "when": "view == pawnpro.serverView.explorer && pawnpro.server.running",
          "group": "navigation@1"
        },
        {
          "command": "pawnpro.server.show",
          "when": "view == pawnpro.serverView.explorer",
          "group": "navigation@2"
        },
        {
          "command": "pawnpro.server.showLog",
          "when": "view == pawnpro.serverView.explorer && pawnpro.server.running",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "pawnpro.server.start",
          "when": "true"
        },
        {
          "command": "pawnpro.server.stop",
          "when": "true"
        },
        {
          "command": "pawnpro.server.restart",
          "when": "true"
        },
        {
          "command": "pawnpro.server.show",
          "when": "true"
        },
        {
          "command": "pawnpro.server.showLog",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc --noEmit -p .",
    "bundle": "node scripts/bundle.mjs",
    "bundle:dev": "node scripts/bundle.mjs --dev",
    "vscode:prepublish": "npm run bundle",
    "watch": "node scripts/bundle.mjs --watch",
    "package": "npm run package:full",
    "package:full": "npm run bundle && npx @vscode/vsce package --no-dependencies --no-yarn && node scripts/repack-vsix.js",
    "package:pre": "npm run bundle && npx @vscode/vsce package --pre-release --no-dependencies --no-yarn && node scripts/repack-vsix.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "1.106.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "jszip": "^3.10.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "vscode-languageclient": "^9.0.1",
    "vscode-nls": "^5.2.0"
  },
  "overrides": {
    "@vscode/vsce": {
      "minimatch": "3.1.5"
    },
    "minimatch": "10.2.3",
    "qs": "6.14.2",
    "ajv": "8.18.0",
    "markdown-it": "14.1.1",
    "underscore": "1.13.8"
  }
}
